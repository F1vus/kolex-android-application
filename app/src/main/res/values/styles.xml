<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="AppButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:backgroundTint">#AACC00</item>
        <item name="android:textColor">@color/black</item>

    </style>

    <style name="BottomNavIndicator" parent="">
        <item name="android:color">@color/green</item>
<!--        <item name="android:sha">@style/BottomNavIndicatorShape</item>-->
    </style>

    <style name="BottomNavIndicatorShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    // Source - https://stackoverflow.com/q/53405483
